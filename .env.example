# Configuración de Base de Datos (Supabase o Postgres Local)
# Para Supabase, usa el "Transaction connection string" o "Session connection string" (pooling)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drenacruz

# Supabase SDK Credentials (para subida de imágenes y autenticación)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# API Key de Google Gemini
GEMINI_API_KEY=your-gemini-api-key
